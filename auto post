      "parameters": {
        "jsCode": "// Parse the AI analysis response\nconst response = $input.first().json;\nlet analysisText = '';\n\nif (response.choices && response.choices[0]) {\n  analysisText = response.choices[0].message?.content || '';\n} else if (response.body) {\n  analysisText = typeof response.body === 'string' ? response.body : JSON.stringify(response.body);\n}\n\nlet analysis = {};\n\ntry {\n  const jsonMatch = analysisText.match(/\\{[\\s\\S]*\\}/);\n  if (jsonMatch) {\n    analysis = JSON.parse(jsonMatch[0]);\n  }\n} catch (e) {\n  analysis = {\n    selected_topic: 'AI-Powered Digital Marketing Strategies for 2026',\n    content_niche: 'Digital Marketing',\n    brand_name: 'Marvice',\n    mention_brand: false,\n    why_trending: 'AI tools are transforming how businesses run marketing campaigns',\n    target_audience: 'Business owners, startups, marketers, and decision-makers',\n    campaign_angle: 'How AI is reshaping digital marketing ROI in 2026',\n    hashtags: ['#DigitalMarketing', '#AIMarketing', '#MarketingTrends', '#SEO2026', '#ContentMarketing', '#SocialMediaMarketing', '#GrowthHacking', '#MarketingStrategy', '#AITools', '#BusinessGrowth'],\n    mood_keywords: ['professional', 'vibrant', 'data-driven', 'modern', 'trustworthy'],\n    key_takeaway: 'AI-powered marketing tools are delivering 3x better engagement rates',\n    lead_hook: 'DM us or visit our page for a free consultation',\n    blog_title: 'AI-Powered Digital Marketing: The Complete Strategy Guide for 2026'\n  };\n}\n\n// Enforce brand rules\nif (analysis.content_niche === 'Corporate Gifting') {\n  analysis.brand_name = 'Conxyou';\n  analysis.mention_brand = true;\n} else if (!analysis.brand_name) {\n  analysis.brand_name = 'Marvice';\n}\n\nreturn [{\n  json: {\n    ...analysis,\n    timestamp: new Date().toISOString()\n  }\n}];"
      },
