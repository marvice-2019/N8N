      "parameters": {
        "jsCode": "// Aggregate and parse all content sources into a unified trending topics list\n// DAILY TOPIC ROTATION: Each day of the week focuses on a different niche\nconst allInputs = $input.all();\nconst allTopics = [];\n\nconst categories = ['google_trends', 'ai_tech', 'digital_marketing', 'web_development', 'corporate_gifting'];\nconst categoryLabels = {\n  'google_trends': 'General Trends',\n  'ai_tech': 'AI & Technology',\n  'digital_marketing': 'Digital Marketing',\n  'web_development': 'Web Development',\n  'corporate_gifting': 'Corporate Gifting'\n};\n\n// Daily topic rotation schedule (0=Sunday, 6=Saturday)\nconst dayOfWeek = new Date().getDay();\nconst dailyTopicSchedule = {\n  0: 'Corporate Gifting',     // Sunday - Conxyou\n  1: 'AI & Technology',       // Monday - Marvice\n  2: 'Digital Marketing',     // Tuesday - Marvice sometimes\n  3: 'Web Development',       // Wednesday - Marvice\n  4: 'Corporate Gifting',     // Thursday - Conxyou\n  5: 'AI & Technology',       // Friday - Marvice\n  6: 'Digital Marketing'      // Saturday - Marketing Updates\n};\nconst todaysFocus = dailyTopicSchedule[dayOfWeek];\n\nfor (let i = 0; i < allInputs.length; i++) {\n  const rawData = allInputs[i].json.data || allInputs[i].json.body || '';\n  let text = typeof rawData === 'string' ? rawData : JSON.stringify(rawData);\n  const category = categories[i] || 'general';\n  \n  if (category === 'google_trends') {\n    if (text.startsWith(')]}')) text = text.substring(5);\n    try {\n      const parsed = JSON.parse(text);\n      const days = parsed?.default?.trendingSearchesDays || [];\n      for (const day of days) {\n        for (const trend of (day.trendingSearches || []).slice(0, 3)) {\n          allTopics.push({\n            title: trend.title?.query || '',\n            snippet: trend.articles?.[0]?.snippet || '',\n            source: trend.articles?.[0]?.source || 'Google Trends',\n            category: categoryLabels[category],\n            traffic: trend.formattedTraffic || ''\n          });\n        }\n      }\n    } catch(e) {}\n  } else {\n    const itemRegex = /<item>([\\s\\S]*?)<\\/item>/g;\n    let match;\n    let count = 0;\n    while ((match = itemRegex.exec(text)) !== null && count < 3) {\n      const itemXml = match[1];\n      const titleMatch = itemXml.match(/<title><!\\[CDATA\\[(.+?)\\]\\]><\\/title>/) || itemXml.match(/<title>(.+?)<\\/title>/);\n      const descMatch = itemXml.match(/<description><!\\[CDATA\\[(.+?)\\]\\]><\\/description>/) || itemXml.match(/<description>(.+?)<\\/description>/);\n      const sourceMatch = itemXml.match(/<source[^>]*>(.+?)<\\/source>/);\n      const pubDateMatch = itemXml.match(/<pubDate>(.+?)<\\/pubDate>/);\n      \n      if (titleMatch) {\n        allTopics.push({\n          title: titleMatch[1].replace(/<[^>]+>/g, '').trim(),\n          snippet: descMatch ? descMatch[1].replace(/<[^>]+>/g, '').trim().substring(0, 200) : '',\n          source: sourceMatch ? sourceMatch[1] : 'Google News',\n          category: categoryLabels[category],\n          pubDate: pubDateMatch ? pubDateMatch[1] : ''\n        });\n        count++;\n      }\n    }\n  }\n}\n\n// Prioritize topics matching today's focus niche\nconst focusTopics = allTopics.filter(t => t.category === todaysFocus);\nconst otherTopics = allTopics.filter(t => t.category !== todaysFocus);\nconst sortedTopics = [...focusTopics, ...otherTopics];\n\nreturn [{\n  json: {\n    trends: sortedTopics.slice(0, 15),\n    categories_covered: Object.values(categoryLabels),\n    todays_focus_niche: todaysFocus,\n    day_of_week: ['Sunday','Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'][dayOfWeek],\n    fetchedAt: new Date().toISOString()\n  }\n}];"
      },
